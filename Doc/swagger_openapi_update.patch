+            type: string
+          description: Required unless provided via `X-Idempotency-Key` header or `body.idempotencyKey`.
+        - name: X-Idempotency-Key
+          in: header
+          required: false
+          schema:
+            type: string
+          description: Alias for `Idempotency-Key`.
+      requestBody:
+        required: true
+        content:
