+                invoice_id: inv_abc123
+                status: paid
+                amount: 5000
+                currency: SAR
+      responses:
+        '200':
+          description: Webhook accepted/processed (including duplicate or ignored events).
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  ok:
+                    type: boolean
+                  message:
+                    type: string
+                    nullable: true
+              examples:
+                applied:
+                  value:
+                    ok: true
+                ignoredNonPaid:
+                  value:
+                    ok: true
+                    message: Ignored non-paid status
+        '400':
+          description: Invalid payload (missing payment identifiers).
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/ErrorResponse'
+              example:
+                ok: false
+                error:
+                  code: INVALID
+                  message: Missing payment identifiers
+        '401':
+          description: Invalid or missing webhook secret token.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/ErrorResponse'
+              example:
+                ok: false
+                error:
+                  code: UNAUTHORIZED
+                  message: Invalid webhook token
+        '404':
+          description: Referenced payment not found.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/ErrorResponse'
+              example:
+                ok: false
+                error:
+                  code: NOT_FOUND
+                  message: Payment not found
+        '409':
+          description: Payload/payment mismatch (id/invoice/amount/currency).
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/ErrorResponse'
+              example:
+                ok: false
+                error:
+                  code: MISMATCH
+                  message: Amount mismatch
+        '500':
+          $ref: '#/components/responses/Internal'
