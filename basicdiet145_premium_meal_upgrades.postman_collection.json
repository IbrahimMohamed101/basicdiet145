      "name": "01 - Read / Diagnostics",
      "description": "Read-only requests for listing configs, candidates, and readiness.",
      "item": [
        {
          "name": "List Premium Upgrade Configs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{bas}}/api/dashboard/premium-upgrades",
              "host": [
                "{{bas}}"
              ],
              "path": [
                "api",
                "dashboard",
                "premium-upgrades"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "const json = pm.response.json();",
                  "pm.test('Response status flag is true', function () { pm.expect(json.status).to.eql(true); });",
                  "const items = Array.isArray(json.data) ? json.data : [];",
                  "pm.test('data is an array', function () { pm.expect(items).to.be.an('array'); });",
                  "const map = {",
                  "  beef_steak: 'beef',",
                  "  shrimp: 'shrimp',",
                  "  salmon: 'salmon',",
                  "  premium_large_salad: 'premiumLargeSalad'",
                  "};",
                  "items.forEach(function (item) {",
                  "  const prefix = map[item.premiumKey];",
                  "  if (prefix) {",
                  "    pm.collectionVariables.set(prefix + 'ConfigId', item.id);",
                  "    pm.collectionVariables.set(prefix + 'Revision', String(item.revision));",
                  "  }",
                  "});",
                  "console.log('Premium upgrade config keys:', items.map(i => i.premiumKey));",
                  "pm.test('Known configs are complete when configs exist', function () {",
                  "  if (items.length > 0) {",
                  "    const keys = items.map(i => i.premiumKey);",
                  "    pm.expect(keys).to.include('beef_steak');",
                  "    pm.expect(keys).to.include('shrimp');",
                  "    pm.expect(keys).to.include('salmon');",
                  "    pm.expect(keys).to.include('premium_large_salad');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
