    {
      "name": "02 - Create Premium Links",
      "description": "Creates PremiumUpgradeConfig records from existing menu sources. Run only when configs are missing; do not create partial configs in production.",
      "item": [
        {
          "name": "Create Beef Steak Premium Upgrade",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{bas}}/api/dashboard/premium-upgrades",
              "host": [
                "{{bas}}"
              ],
              "path": [
                "api",
                "dashboard",
                "premium-upgrades"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceType\": \"menu_option\",\n  \"sourceId\": \"{{beefSourceId}}\",\n  \"sourceProductId\": \"{{basicMealProductId}}\",\n  \"sourceGroupId\": \"{{proteinsGroupId}}\",\n  \"selectionType\": \"premium_meal\",\n  \"displayGroupKey\": \"premium_proteins\",\n  \"upgradeDeltaHalala\": 2000,\n  \"isEnabled\": true,\n  \"isVisible\": true,\n  \"sortOrder\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "const json = pm.response.json();",
                  "pm.test('Response status flag is true', function () { pm.expect(json.status).to.eql(true); });",
                  "pm.test('Created premium upgrade config', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const item = json.data;",
                  "pm.test('premiumKey is beef_steak', function () { pm.expect(item.premiumKey).to.eql('beef_steak'); });",
                  "pm.test('Business rule: does not add meal', function () {",
                  "  pm.expect(item.businessRule.consumesExistingMealSlot).to.eql(true);",
                  "  pm.expect(item.businessRule.doesAddMeal).to.eql(false);",
                  "});",
                  "pm.collectionVariables.set('beefConfigId', item.id);",
                  "pm.collectionVariables.set('beefRevision', String(item.revision));"
                ]
              }
            }
          ]
        },
