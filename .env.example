PORT=3000
JWT_SECRET=CHANGE_ME_JWT_SECRET
DASHBOARD_JWT_SECRET=CHANGE_ME_DASHBOARD_JWT_SECRET
DASHBOARD_JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
RATE_LIMIT_DASHBOARD_LOGIN_WINDOW_MS=900000
RATE_LIMIT_DASHBOARD_LOGIN_MAX=20

# Optional defaults for dashboard seeding (ONLY used in non-production)
DASHBOARD_DEFAULT_SUPERADMIN_EMAIL=admin@basicdiet.com
DASHBOARD_DEFAULT_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DASHBOARD_DEFAULT_SUPERADMIN_ACTIVE=true

# Use one of the following MongoDB variables:
MONGO_URI=mongodb://127.0.0.1:27017/basicdiet145
# MONGODB_URI=mongodb://user:pass@host:port/db

# OTP / WhatsApp
OTP_TTL_MINUTES=5
OTP_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
OTP_HASH_SECRET=CHANGE_ME_OTP_HASH_SECRET
RATE_LIMIT_OTP_WINDOW_MS=60000
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_OTP_VERIFY_WINDOW_MS=60000
RATE_LIMIT_OTP_VERIFY_MAX=10
APP_ACCESS_TOKEN_TTL=31d
TRUST_PROXY=true

# Twilio WhatsApp (required for production OTP)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Moyasar Payment
MOYASAR_SECRET_KEY=CHANGE_ME_MOYASAR_SECRET_KEY
# UNIFIED OTP TEST MODE
# Requires BOTH to be true, and in production-like staging it also requires
# ALLOW_STAGING_TEST_AUTH=true. Test OTP is restricted to OTP_TEST_PHONE only.
OTP_TEST_MODE=false
ALLOW_TEST_AUTH=false
ALLOW_STAGING_TEST_AUTH=false
# Required when test auth is enabled
# OTP_TEST_PHONE=+201000000000
# OTP_TEST_CODE=123456

# Application URL (used for redirect validation)
APP_URL=http://localhost:3000
