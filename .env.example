PORT=3000
JWT_SECRET=change_me
DASHBOARD_JWT_SECRET=change_me_dashboard_jwt_secret
DASHBOARD_JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
RATE_LIMIT_DASHBOARD_LOGIN_WINDOW_MS=900000
RATE_LIMIT_DASHBOARD_LOGIN_MAX=20

# Optional defaults for dashboard seeding
