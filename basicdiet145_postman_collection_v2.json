              "raw": "{\n  \"planId\": \"{{planId}}\",\n  \"grams\": {{grams}},\n  \"mealsPerDay\": {{mealsPerDay}},\n  \"startDate\": \"{{startDate}}\",\n  \"delivery\": {\n    \"type\": \"delivery\",\n    \"zoneId\": \"{{zoneId}}\",\n    \"address\": {\n      \"line1\": \"Test Residence\",\n      \"line2\": \"Building 101\",\n      \"city\": \"Riyadh\",\n      \"district\": \"Al Malqa\",\n      \"street\": \"King Fahd Road\",\n      \"building\": \"101\",\n      \"apartment\": \"1A\"\n    },\n    \"slot\": {\n      \"type\": \"delivery\",\n      \"window\": \"{{deliveryWindow}}\"\n    }\n  },\n  \"premiumItems\": [\n    {\n      \"proteinId\": \"{{proteinId}}\",\n      \"qty\": 1\n    }\n  ],\n  \"addons\": [],\n  \"idempotencyKey\": \"checkout-{{$timestamp}}-{{$randomInt}}\"\n}"
            }
