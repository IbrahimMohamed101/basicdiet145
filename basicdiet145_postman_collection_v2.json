    {
      "name": "📋 Subscriptions — Activation",
      "item": [
        {
          "name": "Get Checkout Draft Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "",
                  "console.log('Draft Status:', JSON.stringify(json));",
                  "",
                  "// Check if draft is completed (has subscriptionId)",
                  "if (data.subscriptionId) {",
                  "  pm.collectionVariables.set('subscriptionId', data.subscriptionId);",
                  "  console.log('✅ Saved subscriptionId from draft:', data.subscriptionId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/subscriptions/checkout-drafts/{{checkoutDraftId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "subscriptions", "checkout-drafts", "{{checkoutDraftId}}"]
            }
          }
        },
        {
          "name": "Activate Subscription",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "console.log('Activation Response:', JSON.stringify(json));",
                  "",
                  "const ok = json.ok === true || json.status === true;",
                  "pm.test('Response ok:true', () => pm.expect(ok).to.be.true);",
                  "",
                  "const data = json.data || json;",
                  "",
                  "// Extract subscription ID from various possible paths",
                  "const subId =",
                  "  data.id ||",
                  "  data._id ||",
                  "  data.subscriptionId ||",
                  "  (data.subscription && (data.subscription.id || data.subscription._id));",
                  "",
                  "if (subId) {",
                  "  pm.collectionVariables.set('subscriptionId', subId);",
                  "  console.log('✅ Saved subscriptionId:', subId);",
                  "}",
                  "",
                  "if (data.status === 'active') {",
                  "  console.log('✅ Subscription is ACTIVE');",
                  "}",
                  "",
                  "// Extract dayDate for meal selection",
                  "if (data.startDate) {",
                  "  const startDate = new Date(data.startDate);",
                  "  const dayDate = new Date(startDate.getTime() + 24*60*60*1000);",
                  "  const dayDateStr = dayDate.toISOString().split('T')[0];",
                  "  pm.collectionVariables.set('dayDate', dayDateStr);",
                  "  console.log('✅ Saved dayDate:', dayDateStr);",
                  "}"
                ]
              }
            }
          ],
          "request": {
