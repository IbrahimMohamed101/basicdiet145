    {
      "name": "📊 Subscriptions — Overview",
      "item": [
        {
          "name": "Get Current Subscription Overview",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "",
                  "const ok = json.ok === true || json.status === true;",
                  "pm.test('Response ok:true', () => pm.expect(ok).to.be.true);",
                  "",
                  "pm.test('Has premiumBalance or premiumSummary', () => {",
                  "  const hasPremium = data.premiumBalance || data.premiumSummary;",
                  "  pm.expect(hasPremium).to.exist;",
